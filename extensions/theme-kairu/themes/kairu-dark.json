	"tokenColors": [
		{
			"scope": ["comment", "punctuation.definition.comment"],
			"settings": {
				"foreground": "#5A5D63",
				"fontStyle": "italic"
			}
		},
		{
			"scope": ["string", "string.quoted", "string.template", "string.unquoted"],
			"settings": {
				"foreground": "#A8D89B"
			}
		},
		{
			"scope": ["string.regexp", "constant.character.escape"],
			"settings": {
				"foreground": "#E5C07B"
			}
		},
		{
			"scope": ["constant.numeric", "constant.language", "constant.other"],
			"settings": {
				"foreground": "#E5C07B"
			}
		},
		{
			"scope": ["constant.language.boolean", "constant.language.null", "constant.language.undefined"],
			"settings": {
				"foreground": "#C792EA"
			}
		},
		{
			"scope": ["keyword", "keyword.control", "keyword.control.flow", "keyword.control.import", "keyword.control.from", "keyword.other.using"],
			"settings": {
				"foreground": "#C792EA"
			}
		},
		{
			"scope": ["keyword.operator.new", "keyword.operator.delete", "keyword.operator.expression"],
			"settings": {
				"foreground": "#C792EA"
			}
		},
		{
			"scope": ["storage", "storage.type", "storage.modifier", "storage.type.function", "storage.type.contract", "storage.type.solidity"],
			"settings": {
				"foreground": "#82AAFF"
			}
		},
		{
			"scope": ["keyword.operator", "keyword.operator.assignment", "keyword.operator.arithmetic", "keyword.operator.comparison", "keyword.operator.logical"],
			"settings": {
				"foreground": "#89DDFF"
			}
		},
		{
			"scope": ["entity.name.function", "support.function", "meta.function-call.generic", "meta.function-call entity.name.function", "variable.function"],
			"settings": {
				"foreground": "#82AAFF"
			}
		},
		{
			"scope": ["support.function.builtin", "support.function.console"],
			"settings": {
				"foreground": "#7FDBFF"
			}
		},
		{
			"scope": ["entity.name.class", "entity.name.type", "entity.name.type.class", "support.class", "support.type", "support.type.primitive", "entity.other.inherited-class"],
			"settings": {
				"foreground": "#FFCB6B"
			}
		},
		{
			"scope": ["entity.name.namespace", "entity.name.module"],
			"settings": {
				"foreground": "#FFCB6B"
			}
		},
		{
			"scope": ["variable", "variable.other", "variable.other.readwrite", "meta.object-literal.key", "support.variable"],
			"settings": {
				"foreground": "#E4E4E7"
			}
		},
		{
			"scope": ["variable.parameter"],
			"settings": {
				"foreground": "#F78C6C"
			}
		},
		{
			"scope": ["variable.language", "variable.language.this", "variable.language.self", "variable.language.super"],
			"settings": {
				"foreground": "#FF5370",
				"fontStyle": "italic"
			}
		},
		{
			"scope": ["variable.other.constant", "variable.other.enummember", "support.constant"],
			"settings": {
				"foreground": "#E5C07B"
			}
		},
		{
			"scope": ["entity.other.attribute-name", "entity.other.attribute-name.html"],
			"settings": {
				"foreground": "#FFCB6B"
			}
		},
		{
			"scope": ["entity.name.tag", "punctuation.definition.tag"],
			"settings": {
				"foreground": "#FF5370"
			}
		},
		{
			"scope": ["punctuation", "meta.brace", "meta.delimiter", "punctuation.separator", "punctuation.terminator"],
			"settings": {
				"foreground": "#89DDFF"
			}
		},
		{
			"scope": ["punctuation.definition.string", "punctuation.definition.template-expression"],
			"settings": {
				"foreground": "#A8D89B"
			}
		},
		{
			"scope": ["invalid", "invalid.illegal"],
			"settings": {
				"foreground": "#F87171"
			}
		},
		{
			"scope": ["meta.preprocessor", "keyword.control.directive"],
			"settings": {
				"foreground": "#C792EA"
			}
		},
		{
			"scope": ["markup.bold"],
			"settings": {
				"foreground": "#FAFAFA",
				"fontStyle": "bold"
			}
		},
		{
			"scope": ["markup.italic"],
			"settings": {
				"foreground": "#E4E4E7",
				"fontStyle": "italic"
			}
		},
		{
			"scope": ["markup.heading"],
			"settings": {
				"foreground": "#82AAFF",
				"fontStyle": "bold"
			}
		},
		{
			"scope": ["markup.deleted"],
			"settings": {
				"foreground": "#F87171"
			}
		},
		{
			"scope": ["markup.inserted"],
			"settings": {
				"foreground": "#A8D89B"
			}
		},
		{
			"scope": ["markup.changed"],
			"settings": {
				"foreground": "#E5C07B"
			}
		},
		{
			"name": "JSON keys",
			"scope": ["support.type.property-name.json", "string.quoted.double.json support.type.property-name.json"],
			"settings": {
				"foreground": "#82AAFF"
			}
		},
		{
			"name": "Solidity — pragma directive",
			"scope": ["meta.pragma.solidity", "keyword.other.pragma.solidity"],
			"settings": {
				"foreground": "#C792EA"
			}
		},
		{
			"name": "Solidity — modifier reference",
			"scope": ["meta.modifier.solidity", "entity.name.function.modifier.solidity"],
			"settings": {
				"foreground": "#FF5370",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Solidity — contract / library / interface name",
			"scope": ["entity.name.type.contract.solidity", "entity.name.type.library.solidity", "entity.name.type.interface.solidity"],
			"settings": {
				"foreground": "#FFCB6B"
			}
		},
		{
			"name": "Solidity — built-in types",
			"scope": ["support.type.primitive.solidity", "keyword.type.solidity"],
			"settings": {
				"foreground": "#82AAFF"
			}
		},
		{
			"name": "Solidity — visibility / mutability keywords",
			"scope": ["storage.modifier.visibility.solidity", "storage.modifier.mutability.solidity", "storage.modifier.solidity"],
			"settings": {
				"foreground": "#C792EA",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Solidity — global variables (msg, block, tx, this)",
			"scope": ["variable.language.solidity", "support.variable.solidity"],
			"settings": {
				"foreground": "#FF5370"
			}
		},
		{
			"name": "Solidity — events",
			"scope": ["entity.name.function.event.solidity", "meta.event.solidity"],
			"settings": {
				"foreground": "#FFCB6B"
			}
		}
	],
	"semanticHighlighting": true,
	"semanticTokenColors": {
		"namespace": "#FFCB6B",
		"class": "#FFCB6B",
		"interface": "#FFCB6B",
		"struct": "#FFCB6B",
		"enum": "#FFCB6B",
