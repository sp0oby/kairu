	"ERC20 minimal": {
		"prefix": "kerc20",
		"description": "Kairu — Minimal ERC20 implementation (no OpenZeppelin dependency)",
		"body": [
			"// SPDX-License-Identifier: MIT",
			"pragma solidity ^0.8.24;",
			"",
			"contract ${1:MyToken} {",
			"\tstring public name = \"${2:My Token}\";",
			"\tstring public symbol = \"${3:MTK}\";",
			"\tuint8 public constant decimals = 18;",
			"\tuint256 public totalSupply;",
			"",
			"\tmapping(address => uint256) public balanceOf;",
			"\tmapping(address => mapping(address => uint256)) public allowance;",
			"",
			"\tevent Transfer(address indexed from, address indexed to, uint256 amount);",
			"\tevent Approval(address indexed owner, address indexed spender, uint256 amount);",
			"",
			"\tfunction transfer(address to, uint256 amount) external returns (bool) {",
			"\t\tbalanceOf[msg.sender] -= amount;",
			"\t\tunchecked { balanceOf[to] += amount; }",
			"\t\temit Transfer(msg.sender, to, amount);",
			"\t\treturn true;",
			"\t}",
			"",
			"\tfunction approve(address spender, uint256 amount) external returns (bool) {",
			"\t\tallowance[msg.sender][spender] = amount;",
			"\t\temit Approval(msg.sender, spender, amount);",
			"\t\treturn true;",
			"\t}",
			"",
			"\tfunction transferFrom(address from, address to, uint256 amount) external returns (bool) {",
			"\t\tuint256 allowed = allowance[from][msg.sender];",
			"\t\tif (allowed != type(uint256).max) allowance[from][msg.sender] = allowed - amount;",
			"\t\tbalanceOf[from] -= amount;",
			"\t\tunchecked { balanceOf[to] += amount; }",
			"\t\temit Transfer(from, to, amount);",
			"\t\treturn true;",
			"\t}",
			"\t${0}",
			"}",
			""
		]
	},

	"EIP-712 domain separator": {
		"prefix": "keip712",
		"description": "Kairu — EIP-712 domain separator + typed data hash helper",
		"body": [
			"bytes32 private constant _DOMAIN_TYPEHASH =",
			"\tkeccak256(\"EIP712Domain(string name,string version,uint256 chainId,address verifyingContract)\");",
			"",
			"function _domainSeparator() internal view returns (bytes32) {",
			"\treturn keccak256(abi.encode(",
			"\t\t_DOMAIN_TYPEHASH,",
			"\t\tkeccak256(bytes(\"${1:ContractName}\")),",
			"\t\tkeccak256(bytes(\"${2:1}\")),",
			"\t\tblock.chainid,",
			"\t\taddress(this)",
			"\t));",
			"}",
			"",
			"function _hashTypedData(bytes32 structHash) internal view returns (bytes32) {",
			"\treturn keccak256(abi.encodePacked(\"\\x19\\x01\", _domainSeparator(), structHash));",
			"}",
			"$0"
		]
	},

	"ERC-2612 Permit": {
		"prefix": "kpermit",
		"description": "Kairu — ERC-2612 permit() function for gasless ERC20 approvals",
		"body": [
			"bytes32 private constant _PERMIT_TYPEHASH =",
			"\tkeccak256(\"Permit(address owner,address spender,uint256 value,uint256 nonce,uint256 deadline)\");",
			"",
			"mapping(address => uint256) public nonces;",
			"",
			"function permit(",
			"\taddress owner,",
			"\taddress spender,",
			"\tuint256 value,",
			"\tuint256 deadline,",
			"\tuint8 v,",
			"\tbytes32 r,",
			"\tbytes32 s",
			") external {",
			"\tif (block.timestamp > deadline) revert PermitExpired();",
			"\tbytes32 structHash = keccak256(abi.encode(",
			"\t\t_PERMIT_TYPEHASH,",
			"\t\towner,",
			"\t\tspender,",
			"\t\tvalue,",
			"\t\tnonces[owner]++,",
			"\t\tdeadline",
			"\t));",
			"\tbytes32 digest = _hashTypedData(structHash);",
			"\taddress signer = ecrecover(digest, v, r, s);",
			"\tif (signer != owner || signer == address(0)) revert InvalidSignature();",
			"\tallowance[owner][spender] = value;",
			"\temit Approval(owner, spender, value);",
			"}",
			"$0"
		]
	},

	"Merkle proof verification": {
		"prefix": "kmerkle",
		"description": "Kairu — verify a Merkle proof (whitelist / airdrop pattern)",
		"body": [
			"bytes32 public ${1:merkleRoot};",
			"mapping(address => bool) public ${2:claimed};",
			"",
			"error AlreadyClaimed();",
			"error InvalidProof();",
			"",
			"function ${3:claim}(bytes32[] calldata proof, ${4:uint256 amount}) external {",
			"\tif (${2:claimed}[msg.sender]) revert AlreadyClaimed();",
			"\tbytes32 leaf = keccak256(abi.encodePacked(msg.sender${5:, amount}));",
			"\tbytes32 node = leaf;",
			"\tfor (uint256 i = 0; i < proof.length; i++) {",
			"\t\tnode = node < proof[i]",
			"\t\t\t? keccak256(abi.encodePacked(node, proof[i]))",
			"\t\t\t: keccak256(abi.encodePacked(proof[i], node));",
			"\t}",
			"\tif (node != ${1:merkleRoot}) revert InvalidProof();",
			"\t${2:claimed}[msg.sender] = true;",
			"\t${0}",
			"}",
			""
		]
	},

	"ECDSA recover (signed message)": {
		"prefix": "kecdsa",
		"description": "Kairu — recover signer from a signed message hash (with EIP-191 prefix)",
		"body": [
			"function recoverSigner(bytes32 hash, bytes calldata signature) public pure returns (address) {",
			"\trequire(signature.length == 65, \"bad sig length\");",
			"\tbytes32 r;",
			"\tbytes32 s;",
			"\tuint8 v;",
			"\tassembly {",
			"\t\tr := calldataload(signature.offset)",
			"\t\ts := calldataload(add(signature.offset, 0x20))",
			"\t\tv := byte(0, calldataload(add(signature.offset, 0x40)))",
			"\t}",
			"\tbytes32 prefixed = keccak256(abi.encodePacked(\"\\x19Ethereum Signed Message:\\n32\", hash));",
			"\taddress signer = ecrecover(prefixed, v, r, s);",
			"\trequire(signer != address(0), \"invalid sig\");",
			"\treturn signer;",
			"}",
			"$0"
		]
	},

