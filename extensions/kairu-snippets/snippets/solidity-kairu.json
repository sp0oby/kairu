	"Foundry test scaffold": {
		"prefix": "ktest",
		"description": "Kairu — Foundry test contract with setUp, happy-path test, and fuzz test",
		"body": [
			"// SPDX-License-Identifier: MIT",
			"pragma solidity ^0.8.24;",
			"",
			"import {Test, console} from \"forge-std/Test.sol\";",
			"import {${1:Target}} from \"../src/${1:Target}.sol\";",
			"",
			"contract ${1:Target}Test is Test {",
			"\t${1:Target} public ${2:target};",
			"\taddress public alice = makeAddr(\"alice\");",
			"\taddress public bob = makeAddr(\"bob\");",
			"",
			"\tfunction setUp() public {",
			"\t\t${2:target} = new ${1:Target}(${3});",
			"\t}",
			"",
			"\tfunction test_${4:behavior}() public {",
			"\t\t${0}",
			"\t}",
			"",
			"\tfunction testFuzz_${5:behavior}(uint256 amount) public {",
			"\t\tvm.assume(amount > 0 && amount < type(uint128).max);",
			"\t\t// fuzz body",
			"\t}",
			"",
			"\tfunction test_RevertWhen_${6:condition}() public {",
			"\t\tvm.expectRevert();",
			"\t\t// trigger revert",
			"\t}",
			"}",
			""
		]
	},

