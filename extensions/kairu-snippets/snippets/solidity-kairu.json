			"\t${5:// success}",
			"} catch Error(string memory reason) {",
			"\t// External revert(\"...\")",
			"\temit ${6:CallFailed}(reason);",
			"} catch Panic(uint256 errorCode) {",
			"\t// Solidity panic (assert, divide-by-zero, etc.)",
			"\temit ${6:CallFailed}(string(abi.encodePacked(\"panic 0x\", errorCode)));",
			"} catch (bytes memory rawData) {",
			"\t// Custom error or other low-level revert",
			"\temit ${6:CallFailed}(string(rawData));",
			"}",
			"$0"
		]
	},

	"Bitmap storage (cheap booleans)": {
		"prefix": "kbitmap",
		"description": "Kairu — packed bitmap storage for cheap bulk-boolean state (e.g. claimed flags)",
		"body": [
			"mapping(uint256 => uint256) private _bitmap;",
			"",
			"function _isSet(uint256 index) internal view returns (bool) {",
			"\tuint256 wordIndex = index / 256;",
			"\tuint256 bitIndex = index % 256;",
			"\treturn (_bitmap[wordIndex] >> bitIndex) & 1 == 1;",
			"}",
			"",
			"function _set(uint256 index) internal {",
			"\tuint256 wordIndex = index / 256;",
			"\tuint256 bitIndex = index % 256;",
			"\t_bitmap[wordIndex] |= (1 << bitIndex);",
			"}",
			"",
			"function _unset(uint256 index) internal {",
			"\tuint256 wordIndex = index / 256;",
			"\tuint256 bitIndex = index % 256;",
			"\t_bitmap[wordIndex] &= ~(1 << bitIndex);",
			"}",
			"$0"
		]
	},

	"Ownable2Step": {
		"prefix": "kown2",
		"description": "Kairu — two-step ownership transfer (safer than direct transferOwnership)",
		"body": [
			"address public owner;",
			"address public pendingOwner;",
			"",
			"event OwnershipTransferStarted(address indexed previousOwner, address indexed pendingOwner);",
			"event OwnershipTransferred(address indexed previousOwner, address indexed newOwner);",
			"",
			"error NotOwner();",
			"error NotPendingOwner();",
			"",
			"modifier onlyOwner() {",
			"\tif (msg.sender != owner) revert NotOwner();",
			"\t_;",
			"}",
			"",
			"function transferOwnership(address newOwner) external onlyOwner {",
			"\tpendingOwner = newOwner;",
			"\temit OwnershipTransferStarted(owner, newOwner);",
			"}",
			"",
			"function acceptOwnership() external {",
			"\tif (msg.sender != pendingOwner) revert NotPendingOwner();",
			"\taddress oldOwner = owner;",
			"\towner = pendingOwner;",
			"\tdelete pendingOwner;",
			"\temit OwnershipTransferred(oldOwner, owner);",
			"}",
			"$0"
		]
	},

	"Linear vesting schedule": {
		"prefix": "kvest",
		"description": "Kairu — linear vesting with cliff (release tokens over time)",
		"body": [
			"uint256 public immutable start;",
			"uint256 public immutable cliff;",
			"uint256 public immutable duration;",
			"uint256 public released;",
			"",
			"function vestedAmount() public view returns (uint256) {",
			"\tif (block.timestamp < cliff) return 0;",
			"\tif (block.timestamp >= start + duration) return ${1:totalAllocation};",
			"\treturn (${1:totalAllocation} * (block.timestamp - start)) / duration;",
			"}",
			"",
			"function releasable() public view returns (uint256) {",
			"\treturn vestedAmount() - released;",
			"}",
			"",
			"function release() external {",
			"\tuint256 amount = releasable();",
			"\trequire(amount > 0, \"nothing to release\");",
			"\treleased += amount;",
			"\t${2:// transfer tokens}",
			"\t${0}",
			"}",
			""
		]
	},

	"Diamond storage struct": {
		"prefix": "kdiamond",
		"description": "Kairu — Diamond storage pattern (EIP-2535) — namespaced storage for upgradeable facets",
		"body": [
			"library ${1:MyFacet}Storage {",
			"\tbytes32 internal constant SLOT = keccak256(\"kairu.diamond.${2:facet.name}\");",
			"",
			"\tstruct Layout {",
			"\t\t${3:uint256 value;}",
			"\t\t${4:mapping(address => uint256) balances;}",
			"\t}",
			"",
			"\tfunction layout() internal pure returns (Layout storage l) {",
			"\t\tbytes32 slot = SLOT;",
			"\t\tassembly { l.slot := slot }",
			"\t}",
			"}",
			"$0"
		]
	},

	"AccessControl admin role pattern": {
		"prefix": "krole",
		"description": "Kairu — Quick AccessControl: define a custom role + modifier + grant function",
		"body": [
			"bytes32 public constant ${1:OPERATOR_ROLE} = keccak256(\"${1:OPERATOR_ROLE}\");",
			"",
			"mapping(bytes32 => mapping(address => bool)) private _roles;",
			"",
			"event RoleGranted(bytes32 indexed role, address indexed account);",
			"event RoleRevoked(bytes32 indexed role, address indexed account);",
			"",
			"error MissingRole(bytes32 role, address account);",
			"",
			"modifier onlyRole(bytes32 role) {",
			"\tif (!_roles[role][msg.sender]) revert MissingRole(role, msg.sender);",
			"\t_;",
			"}",
			"",
			"function grantRole(bytes32 role, address account) external onlyRole(0x00) {",
			"\t_roles[role][account] = true;",
			"\temit RoleGranted(role, account);",
			"}",
			"",
			"function revokeRole(bytes32 role, address account) external onlyRole(0x00) {",
			"\t_roles[role][account] = false;",
			"\temit RoleRevoked(role, account);",
			"}",
			"$0"
		]
	},

	"Reentrant call detector (pure, gas-cheap)": {
		"prefix": "kreentrant",
		"description": "Kairu — Manual reentrancy guard using transient storage (EIP-1153) for gas-cheap protection",
		"body": [
			"// Requires Solidity ^0.8.24 + a chain that supports transient storage (EIP-1153)",
			"bytes32 private constant _GUARD_SLOT = keccak256(\"kairu.reentrancy.guard\");",
			"",
			"modifier nonReentrantTransient() {",
			"\tassembly {",
			"\t\tif tload(_GUARD_SLOT) { revert(0, 0) }",
			"\t\ttstore(_GUARD_SLOT, 1)",
			"\t}",
			"\t_;",
			"\tassembly { tstore(_GUARD_SLOT, 0) }",
			"}",
			"$0"
		]
	},

	"Bound + clamp helper": {
		"prefix": "kbound",
		"description": "Kairu — Foundry vm.bound() helper for fuzz tests (constrain values to a sane range)",
		"body": [
			"function ${1:fuzz}_test(${2:uint256 amount}, ${3:address user}) public {",
			"\t${2:amount} = bound(${2:amount}, ${4:1}, ${5:type(uint128).max});",
			"\tvm.assume(${3:user} != address(0) && ${3:user} != address(this));",
			"\t${0}",
			"}",
			""
		]
	}
}
