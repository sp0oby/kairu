	"Pull payment pattern": {
		"prefix": "kpull",
		"description": "Kairu — Pull payment pattern (avoids reentrancy in send)",
		"body": [
			"mapping(address => uint256) public pendingWithdrawals;",
			"",
			"function ${1:queueWithdrawal}(address recipient, uint256 amount) internal {",
			"\tpendingWithdrawals[recipient] += amount;",
			"}",
			"",
			"function withdraw() external {",
			"\tuint256 amount = pendingWithdrawals[msg.sender];",
			"\tif (amount == 0) revert NothingToWithdraw();",
			"\tpendingWithdrawals[msg.sender] = 0;",
			"\t(bool success, ) = msg.sender.call{value: amount}(\"\");",
			"\tif (!success) revert TransferFailed();",
			"}",
			"$0"
		]
	},

